<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
body { font-family: Arial; margin: 40px; color: #222; }
h1 { font-size: 28px; margin-bottom: 5px; }
.role { color: #666; margin-bottom: 20px; }
.section { margin-top: 25px; }
.badge { display: inline-block; background:#eee; padding:5px 10px; margin:3px; border-radius:6px; }
</style>
</head>
<body>

<h1>{{name}}</h1>
<div class="role">{{role}}</div>

<div class="section">
  <h2>Skills</h2>
  {{#each skills}}
    <span class="badge">{{this}}</span>
  {{/each}}
</div>

<div class="section">
  <h2>Experience</h2>
  {{#each experience}}
    <p><b>{{company}}</b> — {{position}}</p>
  {{/each}}
</div>

</body>
</html>